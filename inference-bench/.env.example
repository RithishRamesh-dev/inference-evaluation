# ── Backend ──────────────────────────────────────────────────────────────────

# MongoDB connection URI
# Local dev (docker-compose):
MONGODB_URL=mongodb://localhost:27017
# DigitalOcean Managed MongoDB (set as SECRET in DO dashboard):
# MONGODB_URL=mongodb+srv://doadmin:<password>@<host>.mongo.ondigitalocean.com/admin?tls=true&authSource=admin

# MongoDB database name (default: inference_bench)
MONGODB_DB=inference_bench

# Simple API key — baked into frontend bundle as VITE_API_KEY
API_KEY=local-dev-key

# Fernet encryption key for stored API keys.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# DigitalOcean token used ONLY to fetch the droplet catalog (regions/sizes/images)
# for the Benchmarking → Droplets create form. NOT used to create/destroy droplets —
# those use the per-droplet token the user enters (stored encrypted in MongoDB).
# Leave blank to fall back to reference plans in the create form.
DO_API_TOKEN=

# Public URL of this backend. The on-droplet deployment agent calls home here over
# HTTPS (App Platform blocks backend→droplet connections). On App Platform this is
# bound automatically to ${APP_URL}; set it explicitly for local/other hosting.
# Deployments won't run until the droplet's agent can reach this URL.
CREST_PUBLIC_URL=

# ── Frontend (Vite build) ─────────────────────────────────────────────────────
VITE_API_KEY=local-dev-key
